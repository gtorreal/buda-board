PORT=3847
BUDA_JWT_SECRET=change-me-to-a-long-random-string
# Varios emails separados por coma:
BUDA_AUTH_EMAIL=admin@buda.com,usuario@buda.com
# Contraseña (si omites ambas líneas de abajo, el servidor usa "buda-dev" solo en desarrollo):
BUDA_AUTH_PASSWORD=buda-dev
# O SHA-256 hex de la contraseña (producción):
# BUDA_AUTH_PASSWORD_SHA256=

# Google Sheets (obligatorio para la pestaña "EBITDA Live"; el board lee la hoja vía /api/sheets/values)
# ID = parte de la URL: docs.google.com/spreadsheets/d/ESTE_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=
# Clave API (Google Cloud → APIs y servicios → credenciales → clave de API; habilitar "Google Sheets API")
GOOGLE_SHEETS_API_KEY=

# Optional: OpenAI for EEFF narrative analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SQLite + PDF storage
BUDA_DATA_DIR=
